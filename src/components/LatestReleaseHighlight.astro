---
import type { MajorRelease, MinorRelease } from "../data/release-types";

type Props = {
  majorRelease: MajorRelease;
  latestRelease: MinorRelease;
  totalReleaseCount: number;
  majorLineCount: number;
};

const { majorRelease, latestRelease, totalReleaseCount, majorLineCount } = Astro.props;
---

<header class="archive-intro" aria-labelledby="archive-title">
  <p class="archive-intro__eyebrow">
    <span class="brand-mark" aria-hidden="true"></span>
    Java Edition · Official releases
  </p>

  <h1 id="archive-title" class="archive-intro__title">
    <span class="archive-intro__product">Minecraft Java Edition</span>
    <span class="archive-intro__version">{latestRelease.version}</span>
  </h1>

  <div class="archive-intro__meta">
    <span class={`release-label release-label--${latestRelease.label}`}>{latestRelease.label}</span>
    <time datetime={latestRelease.releasedAt}>{latestRelease.releasedAt}</time>
    <span class="archive-intro__dot" aria-hidden="true">·</span>
    <span>{majorRelease.name}</span>
  </div>

  <p class="archive-intro__lead">{latestRelease.summary}</p>

  <dl class="archive-intro__stats">
    <div>
      <dt>{totalReleaseCount}</dt>
      <dd>releases archived</dd>
    </div>
    <div>
      <dt>{majorLineCount}</dt>
      <dd>major version lines</dd>
    </div>
  </dl>
</header>
