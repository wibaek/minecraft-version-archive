---
import type { TocItem } from "../data/release-types";

type Props = {
  items: TocItem[];
};

const { items } = Astro.props;
---

<aside class="toc" aria-label="Major version table of contents">
  <details class="toc__mobile">
    <summary>
      <span>Versions</span>
      <span class="toc__count">{items.length}</span>
    </summary>
    <nav class="toc__mobile-list" aria-label="Major version navigation">
      {
        items.map((item) => (
          <a href={`#${item.id}`} data-toc-link={item.id} title={item.name}>
            <span class="toc__version">{item.label}</span>
            <span class="toc__name">{item.name}</span>
          </a>
        ))
      }
    </nav>
  </details>

  <nav class="toc__desktop" aria-label="Major version navigation">
    <p class="toc__label">On this page</p>
    <div class="toc__list">
      {
        items.map((item) => (
          <a href={`#${item.id}`} data-toc-link={item.id} title={item.name}>
            <span class="toc__version">{item.label}</span>
            <span class="toc__name">{item.name}</span>
          </a>
        ))
      }
    </div>
  </nav>
</aside>

<script>
  const links = Array.from(document.querySelectorAll<HTMLAnchorElement>("[data-toc-link]"));
  const sections = Array.from(document.querySelectorAll<HTMLElement>("[data-major-section]"));
  const desktopList = document.querySelector<HTMLElement>(".toc__list");
  const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  const keepActiveInView = (link: HTMLAnchorElement): void => {
    if (!desktopList || !desktopList.contains(link)) {
      return;
    }

    const linkRect = link.getBoundingClientRect();
    const listRect = desktopList.getBoundingClientRect();

    if (linkRect.top < listRect.top || linkRect.bottom > listRect.bottom) {
      desktopList.scrollTo({
        top: link.offsetTop - desktopList.clientHeight / 2 + link.clientHeight / 2,
        behavior: prefersReducedMotion ? "auto" : "smooth",
      });
    }
  };

  const setActiveSection = (sectionId: string | undefined): void => {
    for (const link of links) {
      const isActive = link.dataset.tocLink === sectionId;
      link.classList.toggle("is-active", isActive);

      if (isActive) {
        link.setAttribute("aria-current", "true");
        keepActiveInView(link);
      } else {
        link.removeAttribute("aria-current");
      }
    }
  };

  if ("IntersectionObserver" in window && sections.length > 0) {
    const observer = new IntersectionObserver(
      (entries) => {
        const visible = entries
          .filter((entry) => entry.isIntersecting)
          .sort((a, b) => b.intersectionRatio - a.intersectionRatio)[0];

        if (visible?.target instanceof HTMLElement) {
          setActiveSection(visible.target.dataset.majorSection);
        }
      },
      {
        rootMargin: "-12% 0px -70% 0px",
        threshold: [0.05, 0.25, 0.5],
      },
    );

    for (const section of sections) {
      observer.observe(section);
    }
  }
</script>
