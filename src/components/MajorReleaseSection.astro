---
import type { MajorRelease } from "../data/release-types";
import { createMajorReleaseId } from "../data/release-utils";
import MinorReleaseItem from "./MinorReleaseItem.astro";

type Props = {
  release: MajorRelease;
};

const { release } = Astro.props;
const sectionId = createMajorReleaseId(release.version);
---

<section
  class="major"
  id={sectionId}
  data-major-section={sectionId}
  aria-labelledby={`${sectionId}-title`}
>
  <div class="major__header">
    <h2 id={`${sectionId}-title`} class="major__heading">{release.version}</h2>
    <time class="major__date" datetime={release.releasedAt}>{release.releasedAt}</time>
  </div>

  <div class="major__body">
    <p class="major__name">{release.name}</p>
    <p class="major__summary">{release.summary}</p>

    <ul class="major__highlights">
      {release.highlights.map((highlight) => <li>{highlight}</li>)}
    </ul>

    <div class="major__releases">
      {release.releases.map((minorRelease) => <MinorReleaseItem release={minorRelease} />)}
    </div>
  </div>
</section>
